SPRING_PROFILES_ACTIVE=dev
SIDEQUEST_CORS_ALLOWED_ORIGINS=http://localhost:5173
SIDEQUEST_LOCATION_PROVIDER=geoapify
SIDEQUEST_GEOAPIFY_API_KEY=replace-with-your-geoapify-key
SIDEQUEST_NOTIFICATIONS_RETENTION_DAYS=7
SIDEQUEST_NOTIFICATIONS_CLEANUP_CRON=0 30 3 * * *
SIDEQUEST_CHAT_IMAGE_RETENTION_DAYS=30
SIDEQUEST_CHAT_MESSAGE_RETENTION_DAYS=180
SIDEQUEST_CHAT_CLEANUP_CRON=0 45 3 * * *
SIDEQUEST_CHAT_EXPIRED_IMAGE_PLACEHOLDER=Image expired
SIDEQUEST_CHAT_ONLINE_WINDOW_SECONDS=120
SIDEQUEST_CHAT_HEARTBEAT_LIMIT_PER_MINUTE=120
SIDEQUEST_CHAT_DEFAULT_PAGE_SIZE=50
SIDEQUEST_CHAT_MAX_PAGE_SIZE=100
SIDEQUEST_CHAT_OPEN_LIMIT_PER_MINUTE=30
SIDEQUEST_CHAT_SEND_LIMIT_PER_MINUTE=40
SIDEQUEST_CHAT_DELIVERY_LIMIT_PER_MINUTE=240
SIDEQUEST_CHAT_READ_LIMIT_PER_MINUTE=120
SIDEQUEST_CHAT_EDIT_WINDOW_SECONDS=900
SIDEQUEST_CHAT_DELETE_WINDOW_SECONDS=3600
SIDEQUEST_CHAT_DELETED_MESSAGE_PLACEHOLDER=Message deleted
SIDEQUEST_CHAT_MAX_IMAGE_BYTES=262144
SIDEQUEST_CHAT_ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif
SIDEQUEST_CHAT_MAX_ATTACHMENT_BYTES=524288
SIDEQUEST_CHAT_ALLOWED_ATTACHMENT_MIME_TYPES=application/pdf,text/plain,application/json,image/jpeg,image/png,image/webp

# Local default: backend stores attachments on disk and serves them back through /chat/attachments/object.
SIDEQUEST_OBJECT_STORAGE_ENABLED=true
SIDEQUEST_OBJECT_STORAGE_PROVIDER=local
SIDEQUEST_OBJECT_STORAGE_LOCAL_BASE_PATH=/tmp/themuffinman-object-storage
SIDEQUEST_OBJECT_STORAGE_LOCAL_PROXY_BASE_URL=/chat/attachments/object

# MinIO / S3-compatible alternative:
# SIDEQUEST_OBJECT_STORAGE_PROVIDER=s3
# SIDEQUEST_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# SIDEQUEST_OBJECT_STORAGE_REGION=eu-central-1
# SIDEQUEST_OBJECT_STORAGE_BUCKET=themuffinman-dev-chat
# SIDEQUEST_OBJECT_STORAGE_ACCESS_KEY=themuffinman
# SIDEQUEST_OBJECT_STORAGE_SECRET_KEY=themuffinman-secret
# SIDEQUEST_OBJECT_STORAGE_PATH_STYLE_ACCESS=true
# SIDEQUEST_OBJECT_STORAGE_PUBLIC_BASE_URL=
# SIDEQUEST_OBJECT_STORAGE_KEY_PREFIX=chat
# SIDEQUEST_OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=900

# OpenAI powers the admin agent summary path and the adaptive voice path.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
