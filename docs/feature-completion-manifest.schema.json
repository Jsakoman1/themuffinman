{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feature Completion Manifest",
  "type": "object",
  "required": ["featureId", "title", "status", "riskTier", "changeMode", "changeImpact", "changeProfiles", "planFile", "backlog", "checklist", "artifacts", "validationEvidence", "generatedArtifacts", "planCompletion", "closeoutDecision"],
  "additionalProperties": false,
  "properties": {
    "featureId": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "workflowTier": {
      "type": "string",
      "enum": ["tier1-tiny-change", "tier2-normal-feature", "tier3-high-risk-multi-layer", "tier4-agent-tooling-workflow"]
    },
    "manifestDecision": {
      "type": "string",
      "enum": ["required", "optional", "resolver_review"]
    },
    "status": {"type": "string", "enum": ["draft", "in_progress", "complete"]},
    "riskTier": {"type": "string", "enum": ["low", "medium", "high", "executor-critical"]},
    "changeMode": {"type": "string", "enum": ["small-change", "major-change"]},
    "changeImpact": {"type": "string", "enum": ["cosmetic", "contract-neutral-refactor", "logic-drift"]},
    "changeProfiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["backend-logic", "agent-contract", "frontend-contract", "workflow-expansion"]
      }
    },
    "planFile": {"type": "string", "pattern": "^\\.agents/.+-plan\\.md$"},
    "summary": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "docDelta": {
      "type": "object",
      "required": ["behaviorChanged", "docsUpdated", "intentionallyUnchanged"],
      "additionalProperties": false,
      "properties": {
        "behaviorChanged": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "docsUpdated": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "intentionallyUnchanged": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "backlog": {
      "type": "object",
      "required": ["reviewed", "createdIds", "resolvedIds"],
      "additionalProperties": false,
      "properties": {
        "reviewed": {"type": "boolean"},
        "createdIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z0-9_-]+$"}
        },
        "resolvedIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z0-9_-]+$"}
        }
      }
    },
    "checklist": {
      "type": "object",
      "required": [
        "tempPlanCreated",
        "codeImplemented",
        "backendTestsPassed",
        "frontendValidationPassed",
        "docsSynced",
        "agentModelSynced",
        "destructivePolicyChecked",
        "multilingualCoverageChecked"
      ],
      "additionalProperties": false,
      "properties": {
        "tempPlanCreated": {"type": "boolean"},
        "codeImplemented": {"type": "boolean"},
        "backendTestsPassed": {"type": "boolean"},
        "frontendValidationPassed": {"type": "boolean"},
        "docsSynced": {"type": "boolean"},
        "agentModelSynced": {"type": "boolean"},
        "destructivePolicyChecked": {"type": "boolean"},
        "multilingualCoverageChecked": {"type": "boolean"}
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["codePaths", "docPaths", "testPaths", "generatorCommands", "auditCommands"],
      "additionalProperties": false,
      "properties": {
        "codePaths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "docPaths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "testPaths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "generatorCommands": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "auditCommands": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "validationEvidence": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["command", "scope", "result", "summary"],
            "additionalProperties": false,
            "properties": {
              "command": {"type": "string", "minLength": 1},
              "scope": {
                "type": "string",
                "enum": ["backend", "frontend", "docs", "generated-artifact", "local-tooling", "agent-safety", "manifest", "smoke", "other"]
              },
              "result": {"type": "string", "enum": ["passed", "failed", "skipped", "not_applicable"]},
              "ranAt": {"type": "string", "minLength": 1},
              "durationSeconds": {"type": "number", "minimum": 0},
              "summary": {"type": "string", "minLength": 1},
              "outputPath": {"type": "string", "minLength": 1},
              "skippedReason": {"type": "string", "minLength": 1}
            },
            "allOf": [
              {
                "if": {
                  "properties": {"result": {"enum": ["skipped", "not_applicable"]}},
                  "required": ["result"]
                },
                "then": {"required": ["skippedReason"]}
              }
            ]
          }
        }
      }
    },
    "generatedArtifacts": {
      "type": "object",
      "required": ["refreshedPaths", "notApplicableReason"],
      "additionalProperties": false,
      "properties": {
        "refreshedPaths": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "notApplicableReason": {"type": "string", "minLength": 1}
      }
    },
    "planCompletion": {
      "type": "object",
      "required": ["reviewed", "openTasks", "summary"],
      "additionalProperties": false,
      "properties": {
        "reviewed": {"type": "boolean"},
        "openTasks": {"type": "integer", "minimum": 0},
        "summary": {"type": "string", "minLength": 1}
      }
    },
    "closeoutDecision": {
      "type": "object",
      "required": ["status", "reason"],
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string", "enum": ["ready", "blocked", "deferred"]},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
