{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Operating Model",
  "type": "object",
  "required": [
    "metadata",
    "source_of_truth",
    "backend_audit_coverage",
    "enums",
    "api",
    "intents",
    "policies",
    "automation_read_models",
    "mutating_intent_contracts",
    "intent_safety_catalog",
    "documentation_coverage",
    "documentation_ownership",
    "frontend_contract_generation",
    "frontend_contracts",
    "frontend_safety_regressions",
    "frontend_feature_expectations",
    "dead_path_tracker",
    "capability_registry",
    "intent_lineage",
    "prompt_drift_detection",
    "backend_contract_snapshots",
    "service_workflow_inventory",
    "permission_matrix",
    "state_transition_audit",
    "request_validation_gate",
    "documentation_sync"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "version",
        "status",
        "default_failure_mode"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["draft", "active"]},
        "default_failure_mode": {"type": "string", "enum": ["fail_closed"]},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "source_of_truth": {
      "type": "object",
      "required": ["files"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/fileRef"}
        }
      }
    },
    "backend_audit_coverage": {
      "type": "object",
      "required": ["current_enforcement", "future_tightening", "domain_ownership", "tiers", "classification_rules"],
      "additionalProperties": false,
      "properties": {
        "current_enforcement": {
          "type": "object",
          "required": ["fail_hard_tiers", "report_only_tiers", "strict_source_of_truth_rule_ids", "strict_documentation_rule_ids"],
          "additionalProperties": false,
          "properties": {
            "fail_hard_tiers": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "report_only_tiers": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "strict_source_of_truth_rule_ids": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "strict_documentation_rule_ids": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "domain_ownership": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "owner_id"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "owner_id": {"type": "string", "minLength": 1},
              "file_names": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "path_prefixes": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "path_contains_any": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "future_tightening": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["phase", "target_tier", "goal"],
            "additionalProperties": false,
            "properties": {
              "phase": {"type": "string", "minLength": 1},
              "target_tier": {"type": "string", "minLength": 1},
              "goal": {"type": "string", "minLength": 1}
            }
          }
        },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "description", "current_gate", "required_artifacts"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "description": {"type": "string", "minLength": 1},
              "current_gate": {"type": "string", "enum": ["fail_hard", "report_only"]},
              "required_artifacts": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "classification_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "tier"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "tier": {"type": "string", "minLength": 1},
              "file_names": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "file_suffixes": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "path_prefixes": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "path_contains_any": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "enums": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "java_class", "values"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "java_class": {"type": "string", "minLength": 1},
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "api": {
      "type": "object",
      "required": ["endpoints"],
      "additionalProperties": false,
      "properties": {
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "method", "path", "controller_class", "handler_method"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "method": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]},
              "path": {"type": "string", "pattern": "^/.*"},
              "controller_class": {"type": "string", "minLength": 1},
              "handler_method": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "mutating",
          "required_inputs",
          "defaults",
          "workflow"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "mutating": {"type": "boolean"},
          "required_inputs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "optional_inputs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "defaults": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "value"],
              "additionalProperties": false,
              "properties": {
                "field": {"type": "string", "minLength": 1},
                "value": {}
              }
            }
          },
          "workflow": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["step", "action", "source_refs"],
              "additionalProperties": false,
              "properties": {
                "step": {"type": "integer", "minimum": 1},
                "when": {"type": "string", "minLength": 1},
                "action": {"type": "string", "minLength": 1},
                "intent_ref": {"type": "string", "minLength": 1},
                "endpoint_id": {"type": "string", "minLength": 1},
                "source_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "string", "minLength": 1}
                },
                "fail_if": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            }
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["self_test_matrix", "validation_evidence_quality", "closeout_doc_delta", "plan_completion_audit", "program_planning_hierarchy", "implementation_checkpoints", "uniqueness", "edge_cases"],
      "additionalProperties": false,
      "properties": {
        "self_test_matrix": {
          "type": "object",
          "required": ["default_rule", "tiers", "risk_tiers", "profile_overrides"],
          "additionalProperties": false,
          "properties": {
            "default_rule": {"type": "string", "minLength": 1},
            "tiers": {
              "type": "array",
              "minItems": 6,
              "items": {
                "type": "object",
                "required": ["id", "purpose", "example_commands"],
                "additionalProperties": false,
                "properties": {
                  "id": {"type": "string", "minLength": 1},
                  "purpose": {"type": "string", "minLength": 1},
                  "example_commands": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  }
                }
              }
            },
            "risk_tiers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["risk", "minimum_tiers"],
                "additionalProperties": false,
                "properties": {
                  "risk": {"type": "string", "minLength": 1},
                  "minimum_tiers": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  }
                }
              }
            },
            "profile_overrides": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["profile", "add_tiers"],
                "additionalProperties": false,
                "properties": {
                  "profile": {"type": "string", "minLength": 1},
                  "add_tiers": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          }
        },
        "validation_evidence_quality": {
          "type": "object",
          "required": ["default_rule", "command_rules", "audit_command"],
          "additionalProperties": false,
          "properties": {
            "default_rule": {"type": "string", "minLength": 1},
            "command_rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "applies_to", "requirement"],
                "additionalProperties": false,
                "properties": {
                  "id": {"type": "string", "minLength": 1},
                  "applies_to": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  },
                  "requirement": {"type": "string", "minLength": 1}
                }
              }
            },
            "audit_command": {"type": "string", "minLength": 1}
          }
        },
        "closeout_doc_delta": {
          "type": "object",
          "required": ["applies_to", "required_fields", "record_in", "completion_rule"],
          "additionalProperties": false,
          "properties": {
            "applies_to": {"type": "string", "minLength": 1},
            "required_fields": {
              "type": "array",
              "minItems": 3,
              "items": {"type": "string", "minLength": 1}
            },
            "record_in": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "completion_rule": {"type": "string", "minLength": 1}
          }
        },
        "plan_completion_audit": {
          "type": "object",
          "required": ["applies_to", "required_evidence", "audit_command", "completion_rule"],
          "additionalProperties": false,
          "properties": {
            "applies_to": {"type": "string", "minLength": 1},
            "required_evidence": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "audit_command": {"type": "string", "minLength": 1},
            "completion_rule": {"type": "string", "minLength": 1}
          }
        },
        "program_planning_hierarchy": {
          "type": "object",
          "required": ["applies_to", "source_doc", "hierarchy", "rules", "closeout_rule"],
          "additionalProperties": false,
          "properties": {
            "applies_to": {"type": "string", "minLength": 1},
            "source_doc": {"type": "string", "minLength": 1},
            "hierarchy": {
              "type": "array",
              "minItems": 4,
              "items": {"type": "string", "minLength": 1}
            },
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "closeout_rule": {"type": "string", "minLength": 1}
          }
        },
        "implementation_checkpoints": {
          "type": "object",
          "required": ["broad_change_trigger", "default_rule", "checkpoints"],
          "additionalProperties": false,
          "properties": {
            "broad_change_trigger": {"type": "string", "minLength": 1},
            "default_rule": {"type": "string", "minLength": 1},
            "checkpoints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "required_evidence", "completion_rule"],
                "additionalProperties": false,
                "properties": {
                  "id": {"type": "string", "minLength": 1},
                  "required_evidence": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  },
                  "completion_rule": {"type": "string", "minLength": 1}
                }
              }
            }
          }
        },
        "uniqueness": {
          "type": "object",
          "required": ["default_rule", "rules"],
          "additionalProperties": false,
          "properties": {
            "default_rule": {"type": "string", "minLength": 1},
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["entity", "must_differ_by"],
                "additionalProperties": false,
                "properties": {
                  "entity": {"type": "string", "minLength": 1},
                  "must_differ_by": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  },
                  "notes": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "edge_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "condition", "resolution", "failure_mode"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "condition": {"type": "string", "minLength": 1},
              "resolution": {"type": "string", "minLength": 1},
              "failure_mode": {"type": "string", "enum": ["fail_closed", "retry_with_precondition", "fallback_to_supported_path"]},
              "source_refs": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "automation_read_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "java_class", "required_fields", "producer_source_refs", "verification_tests"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "java_class": {"type": "string", "minLength": 1},
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "producer_source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "verification_tests": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "mutating_intent_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "intent_id",
          "preconditions",
          "state_changes",
          "side_effects",
          "notifications",
          "blocking_conditions",
          "source_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "intent_id": {"type": "string", "minLength": 1},
          "preconditions": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "state_changes": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "side_effects": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "notifications": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "blocking_conditions": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "intent_safety_catalog": {
      "type": "object",
      "required": [
        "risk_groups",
        "exact_target_resolution",
        "destructive_confirmation",
        "multi_actor_authority",
        "current_location_capability"
      ],
      "additionalProperties": false,
      "properties": {
        "risk_groups": {
          "type": "object",
          "required": ["read_only", "safe_write", "destructive_write", "multi_actor_write", "admin_only_write"],
          "additionalProperties": false,
          "properties": {
            "read_only": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "safe_write": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "destructive_write": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "multi_actor_write": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "admin_only_write": {"type": "array", "items": {"type": "string", "minLength": 1}}
          }
        },
        "exact_target_resolution": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["intent_id", "resolution_workflows", "ambiguity_policy"],
            "additionalProperties": false,
            "properties": {
              "intent_id": {"type": "string", "minLength": 1},
              "resolution_workflows": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "ambiguity_policy": {"type": "string", "enum": ["fail_closed"]}
            }
          }
        },
        "destructive_confirmation": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "multi_actor_authority": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "current_location_capability": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "documentation_coverage": {
      "type": "object",
      "required": ["auto_scans", "required_source_ref_groups"],
      "additionalProperties": false,
      "properties": {
        "auto_scans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "root_path", "path_contains", "file_suffix"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "root_path": {"type": "string", "minLength": 1},
              "path_contains": {"type": "string", "minLength": 1},
              "file_suffix": {"type": "string", "minLength": 1}
            }
          }
        },
        "required_source_ref_groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "source_refs"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "source_refs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "documentation_ownership": {
      "type": "object",
      "required": ["documentation_templates", "domains", "change_categories"],
      "additionalProperties": false,
      "properties": {
        "documentation_templates": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "required": ["id", "label", "template_path", "required_living_docs", "required_sections"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "template_path": {"type": "string", "minLength": 1},
              "required_living_docs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "required_sections": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "required_living_docs", "generated_artifacts", "validation_tests"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "required_living_docs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "generated_artifacts": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "validation_tests": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "change_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "required_living_docs", "generated_artifacts", "validation_commands"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "required_living_docs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "generated_artifacts": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "validation_commands": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "frontend_contract_generation": {
      "type": "object",
      "required": ["script", "check_command", "generated_contract_file", "required_aliases"],
      "additionalProperties": false,
      "properties": {
        "script": {"type": "string", "minLength": 1},
        "check_command": {"type": "string", "minLength": 1},
        "generated_contract_file": {"type": "string", "minLength": 1},
        "enum_namespace_rule": {"type": "string", "minLength": 1},
        "required_aliases": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "frontend_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "backend_java_class", "frontend_contract_file", "frontend_gate_file", "frontend_type", "required_fields"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "backend_java_class": {"type": "string", "minLength": 1},
          "frontend_contract_file": {"type": "string", "minLength": 1},
          "frontend_gate_file": {"type": "string", "minLength": 1},
          "frontend_type": {"type": "string", "minLength": 1},
          "required_fields": {
            "type": "array",
