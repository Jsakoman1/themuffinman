{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Operating Model",
  "type": "object",
  "required": [
    "metadata",
    "source_of_truth",
    "enums",
    "api",
    "intents",
    "policies",
    "documentation_sync"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "version",
        "status",
        "default_failure_mode"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["draft", "active"]},
        "default_failure_mode": {"type": "string", "enum": ["fail_closed"]},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "source_of_truth": {
      "type": "object",
      "required": ["files"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/fileRef"}
        }
      }
    },
    "enums": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "java_class", "values"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "java_class": {"type": "string", "minLength": 1},
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "api": {
      "type": "object",
      "required": ["endpoints"],
      "additionalProperties": false,
      "properties": {
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "method", "path", "controller_class", "handler_method"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "method": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]},
              "path": {"type": "string", "pattern": "^/.*"},
              "controller_class": {"type": "string", "minLength": 1},
              "handler_method": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "mutating",
          "required_inputs",
          "defaults",
          "workflow"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "mutating": {"type": "boolean"},
          "required_inputs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "optional_inputs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "defaults": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "value"],
              "additionalProperties": false,
              "properties": {
                "field": {"type": "string", "minLength": 1},
                "value": {}
              }
            }
          },
          "workflow": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["step", "action", "source_refs"],
              "additionalProperties": false,
              "properties": {
                "step": {"type": "integer", "minimum": 1},
                "when": {"type": "string", "minLength": 1},
                "action": {"type": "string", "minLength": 1},
                "intent_ref": {"type": "string", "minLength": 1},
                "endpoint_id": {"type": "string", "minLength": 1},
                "source_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "string", "minLength": 1}
                },
                "fail_if": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            }
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["uniqueness", "edge_cases"],
      "additionalProperties": false,
      "properties": {
        "uniqueness": {
          "type": "object",
          "required": ["default_rule", "rules"],
          "additionalProperties": false,
          "properties": {
            "default_rule": {"type": "string", "minLength": 1},
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["entity", "must_differ_by"],
                "additionalProperties": false,
                "properties": {
                  "entity": {"type": "string", "minLength": 1},
                  "must_differ_by": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 1}
                  },
                  "notes": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "edge_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "condition", "resolution", "failure_mode"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "condition": {"type": "string", "minLength": 1},
              "resolution": {"type": "string", "minLength": 1},
              "failure_mode": {"type": "string", "enum": ["fail_closed", "retry_with_precondition", "fallback_to_supported_path"]},
              "source_refs": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "documentation_sync": {
      "type": "object",
      "required": ["required_docs", "required_tests", "rules"],
      "additionalProperties": false,
      "properties": {
        "required_docs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "required_tests": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "description", "source_refs", "doc_paths", "must_contain_all"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "description": {"type": "string", "minLength": 1},
              "source_refs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "doc_paths": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              },
              "must_contain_all": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "required": ["id", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1}
      }
    }
  }
}
