{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validation Evidence",
  "type": "object",
  "required": ["changeId", "status", "recordedAt", "summary", "commands", "generatedArtifacts", "skippedChecks"],
  "additionalProperties": false,
  "properties": {
    "changeId": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["draft", "in_progress", "complete"]},
    "recordedAt": {"type": "string", "minLength": 1},
    "summary": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "scope", "result", "ranAt", "summary"],
        "additionalProperties": false,
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "enum": ["backend", "frontend", "docs", "generated-artifact", "local-tooling", "agent-safety", "manifest", "smoke", "other"]},
          "result": {"type": "string", "enum": ["passed", "failed", "skipped", "not_applicable"]},
          "ranAt": {"type": "string", "minLength": 1},
          "durationSeconds": {"type": "number", "minimum": 0},
          "summary": {"type": "string", "minLength": 1},
          "outputPath": {"type": "string", "minLength": 1},
          "skippedReason": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {
              "properties": {"result": {"enum": ["skipped", "not_applicable"]}},
              "required": ["result"]
            },
            "then": {"required": ["skippedReason"]}
          }
        ]
      }
    },
    "generatedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "result", "ranAt", "summary"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "action": {"type": "string", "enum": ["refreshed", "checked_fresh", "not_applicable"]},
          "result": {"type": "string", "enum": ["passed", "failed", "skipped", "not_applicable"]},
          "ranAt": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "outputPath": {"type": "string", "minLength": 1},
          "skippedReason": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {
              "properties": {"result": {"enum": ["skipped", "not_applicable"]}},
              "required": ["result"]
            },
            "then": {"required": ["skippedReason"]}
          }
        ]
      }
    },
    "skippedChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "reason"],
        "additionalProperties": false,
        "properties": {
          "check": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
