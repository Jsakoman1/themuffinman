{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/god-plan.schema.json",
  "title": "God Plan",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "objective",
    "scope",
    "masterPlans",
    "implementationState",
    "pros",
    "cons",
    "risks",
    "decisions",
    "validation"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "blocked", "complete", "archived"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": ["included", "excluded"],
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "array",
          "items": {"type": "string"}
        },
        "excluded": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "masterPlans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "status", "role"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "path": {"type": "string"},
          "status": {"type": "string"},
          "role": {"type": "string"},
          "pros": {
            "type": "array",
            "items": {"type": "string"}
          },
          "cons": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "implementationState": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "pros": {
      "type": "array",
      "items": {"type": "string"}
    },
    "cons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "mitigation"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "mitigation": {"type": "string"}
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "decision": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["requiredChecks", "closeoutRule"],
      "additionalProperties": false,
      "properties": {
        "requiredChecks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "closeoutRule": {
          "type": "string"
        }
      }
    }
  }
}

