{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validation Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "updatedAt",
    "purpose",
    "readWhen",
    "canonicalCommands",
    "manifestRules",
    "heuristics",
    "commonFailures",
    "gatewayHints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 10
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "readWhen": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalCommands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frontendContract",
        "backendLogic",
        "agentContract",
        "workflowExpansion",
        "closeout",
        "controlSystem"
      ],
      "properties": {
        "frontendContract": { "$ref": "#/$defs/stringArray" },
        "backendLogic": { "$ref": "#/$defs/stringArray" },
        "agentContract": { "$ref": "#/$defs/stringArray" },
        "workflowExpansion": { "$ref": "#/$defs/stringArray" },
        "closeout": { "$ref": "#/$defs/stringArray" },
        "controlSystem": { "$ref": "#/$defs/stringArray" }
      }
    },
    "manifestRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "buckets",
        "validationEvidenceScopes",
        "completedManifestRequires"
      ],
      "properties": {
        "buckets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "codePaths",
            "testPaths",
            "docPaths",
            "generatedArtifacts"
          ],
          "properties": {
            "codePaths": { "type": "string", "minLength": 1 },
            "testPaths": { "type": "string", "minLength": 1 },
            "docPaths": { "type": "string", "minLength": 1 },
            "generatedArtifacts": { "type": "string", "minLength": 1 }
          }
        },
        "validationEvidenceScopes": { "$ref": "#/$defs/stringArray" },
        "completedManifestRequires": { "$ref": "#/$defs/stringArray" }
      }
    },
    "heuristics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflowExpansionRequiresScenarioTest",
        "agentContractRequiresGeneratedModelEvidence",
        "canonicalCommandStringsMatter",
        "batchMustBeConsistentBeforeManifestComplete"
      ],
      "properties": {
        "workflowExpansionRequiresScenarioTest": { "type": "boolean" },
        "agentContractRequiresGeneratedModelEvidence": { "type": "boolean" },
        "canonicalCommandStringsMatter": { "type": "boolean" },
        "batchMustBeConsistentBeforeManifestComplete": { "type": "boolean" }
      }
    },
    "commonFailures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symptom", "fix"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "symptom": { "type": "string", "minLength": 1 },
          "fix": { "$ref": "#/$defs/stringArray" }
        }
      }
    },
    "gatewayHints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["autoIncludeWhen", "primaryHumanDoc"],
      "properties": {
        "autoIncludeWhen": { "$ref": "#/$defs/stringArray" },
        "primaryHumanDoc": {
          "type": "string",
          "const": "docs/validation-memory.md"
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
